<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgVendorProfile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:contentDescription="Vendor Profile Image"
            android:src="@drawable/ic_profile_placeholder" />

        <TextView
            android:id="@+id/tvVendorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name: "
            android:paddingTop="8dp" />

        <TextView
            android:id="@+id/tvVendorContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contact: "
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tvVendorCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category: "
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tvVendorLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location: "
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tvVendorMenuItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menu Item: " />


    </LinearLayout>
</ScrollView>